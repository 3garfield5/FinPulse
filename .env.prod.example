# DATABASE
POSTGRES_USER=finpulse
POSTGRES_PASSWORD=use_strong_random_password
POSTGRES_DB=finpulse
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT
SECRET_KEY=use_long_random_secret
ALGORITHM=HS256
ACCESS_EXPIRE_MINUTES=15
REFRESH_EXPIRE_DAYS=7

# LLM
LLM_PROVIDER=ollama
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_MAX_CONCURRENCY=1

# App
ADMIN_EMAIL=admin@example.com
FRONTEND_BASE_URL=https://finpulse.example.com
API_BASE_URL=https://finpulse.example.com/api

# S3
S3_PUBLIC_ENDPOINT=https://s3.example.com
S3_ENDPOINT=http://s3:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=use_strong_access_key
S3_SECRET_KEY=use_strong_secret_key
S3_BUCKET=finpulse
S3_PRESIGN_EXPIRES_SEC=300
